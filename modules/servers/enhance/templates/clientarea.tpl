{* Enhance Module — Client Area *}
<div class="row">
    <div class="col-sm-12">
        <div style="background:#372c62;padding:12px 20px;border-radius:8px;margin-bottom:18px;">
            <img width="150" src="https://community.enhance.com/assets/logo-uf00slfz.png" alt="Enhance">
        </div>
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-globe"></i> {$domain}</h3>
            </div>
            <div class="panel-body" style="text-align:center;padding:2rem;">
                <p style="color:#555;margin-bottom:1.5rem;">
                    Access your hosting control panel to manage websites, emails and databases.<br>
                    <small>PT: Aceda ao painel para gerir websites, emails e bases de dados.</small>
                </p>
                <a href="{$ssoUrl}" class="btn btn-primary btn-lg">
                    <i class="fa fa-sign-in"></i> Login to Panel
                </a>
            </div>
        </div>
    </div>
</div>
